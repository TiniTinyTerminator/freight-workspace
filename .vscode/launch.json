{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "VS Code Freight: Extension",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/editors/vscode-freight",
        "${workspaceFolder}/crates/freight/examples/cpp/hello"
      ],
      "outFiles": [],
      "resolveSourceMapLocations": [
        "${workspaceFolder}/editors/vscode-freight/**",
        "!**/node_modules/**",
        "!${env:HOME}/.vscode-server/**"
      ],
      "skipFiles": [
        "<node_internals>/**",
        "${env:HOME}/.vscode-server/**"
      ],
      "preLaunchTask": "vscode-freight: package"
    }
  ]
}
